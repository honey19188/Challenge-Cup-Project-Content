# ========== 传感器 ==========
def read_mq135():
    global real_air_quality
    val = mq135.read()
    if val < 800: real_air_quality = 0
    elif val < 1200: real_air_quality = 1
    elif val < 1600: real_air_quality = 2
    elif val < 2000: real_air_quality = 3
    else: real_air_quality = 4
    print(f"MQ135: {val} -> {air_str[real_air_quality]}")

# ========== 语音 ==========
def send_voice(text):
    try:
        uart.write(text + '\r\n')
        print(f"TTS: {text}")
    except:
        pass

def get_time_str():
    t = rtc.datetime()
    return f"{t[0]}年{t[1]}月{t[2]}日，{t[4]}点{t[5]}分{t[6]}秒"

def parse_voice_cmd():
    if uart.any():
        raw = uart.read()
        if raw:
            print("Raw UART (hex):", raw.hex())
            if len(raw) >= 6:
                for i in range(len(raw) - 5):
                    chunk = raw[i:i+6]
                    if chunk[0] == 0xAA and chunk[1] == 0x55 and chunk[4] == 0x55 and chunk[5] == 0xAA:
                        cmd = chunk[2]
                        print("Hex command:", hex(cmd))
                        if cmd == 0x01:
                            return ('light_off', None)
                        if 0x02 <= cmd <= 0x09:
                            return ('effect', cmd - 0x02)
                        if cmd == 0x0C:
                            return ('auto_play', None)
                        if cmd == 0x0D:
                            return ('curtain_open', None)
                        if cmd == 0x0E:
                            return ('curtain_close', None)
                        if cmd == 0x0F:
                            return ('preset_temp', 3)
                        if cmd == 0x10:
                            return ('preset_temp', 2)
                        if cmd == 0x11:
                            return ('preset_temp', 0)
                        if cmd == 0x12:
                            return ('preset_temp', 1)
                        if cmd == 0x13:
                            return ('report_current', None)
                        if cmd == 0x14:
                            return ('report_time', None)
    return None

# ========== UI 和灯光 ==========
def update_light():
    if not light_enabled:
        return
    if current_mode == MODE_EFFECT:
        return
    t = temp_presets[preset_index]
    if t < 0:
        color = (0, 0, 255)
    elif t < 15:
        color = (0, 255, 0)
    elif t < 28:
        color = (255, 255, 0)
    else:
        color = (255, 0, 0)
    for i in range(NUM_LEDS):
        led_strip[i] = color
    led_strip.write()

def update_oled():
    global oled_ok, oled, i2c
    if not oled_ok:
        return
    try:
        oled.fill(0)
        if current_mode == MODE_PRESET:
            oled.text("Mode: TEMP PRESET", 0, 0)
            oled.text(f"Set Temp: {temp_presets[preset_index]:.1f}C", 0, 16)
            oled.text(f"Air: {air_str[real_air_quality]}", 0, 32)
            oled.text(f"Preset: {preset_index+1}/4", 0, 48)
        else:
            oled.text("Mode: LIGHT EFFECT", 0, 0)
            oled.text(f"Effect: {virtual_scene+1}", 0, 16)
            oled.text(f"{effect_names[virtual_scene][:12]}", 0, 32)
            oled.text(f"Auto Play: {'ON' if auto_play else 'OFF'}", 0, 48)
        oled.show()
    except OSError as e:
        print("OLED I2C error, reinitializing...", e)
        try:
            i2c = I2C(0, scl=Pin(PIN_I2C_SCL), sda=Pin(PIN_I2C_SDA), freq=5000)
            time.sleep_ms(100)
            devices = i2c.scan()
            if 0x3c in devices or 0x3d in devices:
                addr = 0x3c if 0x3c in devices else 0x3d
                oled = SSD1306_I2C(128, 64, i2c, addr=addr)
                oled_ok = True
                oled.fill(0)
                oled.text("Recovered", 0, 0)
                oled.show()
                print("OLED recovered")
            else:
                oled_ok = False
        except Exception as e2:
            print("OLED reinit failed:", e2)
            oled_ok = False
    except Exception as e:
        print("OLED update error:", e)
        oled_ok = False

def set_preset_temperature(index):
    global preset_index
    preset_index = index % 4
    if current_mode == MODE_PRESET and light_enabled:
        update_light()
        send_voice(f"温度已设置为{temp_presets[preset_index]:.1f}度")
    update_oled()

def report_current_data():
    if current_mode == MODE_PRESET:
        send_voice(f"当前预设温度{temp_presets[preset_index]:.1f}度，空气质量{air_str[real_air_quality]}")
    else:
        send_voice(f"当前灯光效果{virtual_scene+1}，{effect_names[virtual_scene]}")

def report_time():
    time_str = get_time_str()
    send_voice(f"现在时间，{time_str}")
    print(f"报时: {time_str}")

def light_off():
    global light_enabled
    light_enabled = False
    for i in range(NUM_LEDS):
        led_strip[i] = (0, 0, 0)
    led_strip.write()
    send_voice("灯光已关闭")
    update_oled()

def light_on():
    global light_enabled
    light_enabled = True
    if current_mode == MODE_PRESET:
        update_light()
    send_voice("灯光已开启")
    update_oled()

def curtain_open():
    send_voice("窗帘已打开")

def curtain_close():
    send_voice("窗帘已关闭")

# ========== 灯光效果库 ==========
def effect_shengshi(leds, n, t):
    period = 2000
    pos = (t % period) / period * n
    for i in range(n):
        dist = abs(i - pos)
        if dist < 3:
            r, g, b = 255, min(255, int(200 * (1 - dist / 3))), 0
        else:
            r, g, b = 128, 0, 0
        leds[i] = (r, g, b)

def effect_putong(leds, n, t):
    step = (t // 100) % n
    for i in range(n):
        idx = (i + step) % PUTONG_COLORS_LEN
        leds[i] = PUTONG_COLORS[idx]

def effect_fade_alternate(leds, n, t):
    colors = [(255,0,0),(0,255,0),(0,0,255),(255,255,0),(255,0,255),(0,255,255)]
    idx = (t // 500) % len(colors)
    brightness = 0.5 + 0.5 * math.sin(t / 1000 * math.pi)
    r, g, b = colors[idx]
    r = int(r * brightness)
    g = int(g * brightness)
    b = int(b * brightness)
    for i in range(n):
        leds[i] = (r, g, b)

def effect_dual_gradient(leds, n, t):
    pos = (t % 3000) / 3000
    r0 = int(255 * (1 - pos))
    b0 = int(255 * pos)
    for i in range(n):
        leds[i] = (r0, 0, b0)

def effect_scan_bar(leds, n, t):
    width = 8
    period = 1500
    pos = (t % period) / period * (n + width)
    if pos > n:
        pos = 2 * n - pos
    start = int(pos - width/2)
    for i in range(n):
        leds[i] = (0,255,0) if start <= i < start+width else (0,0,0)

def effect_heartbeat(leds, n, t):
    brightness = int(255 * (0.5 + 0.5 * math.sin(t / 1000 * 6.283185))**2)
    for i in range(n):
        leds[i] = (brightness,0,0) if i%2==0 else (0,brightness,0)

def effect_firework(leds, n, t):
    if t % 100 == 0:
        center = random.randint(0, n-1)
        r = random.randint(100,255)
        g = random.randint(100,255)
        b = random.randint(100,255)
        for i in range(n):
            leds[i] = (0,0,0)
        for i in range(max(0,center-5), min(n,center+6)):
            leds[i] = (r,g,b)
    else:
        for i in range(n):
            r,g,b = leds[i]
            leds[i] = (r>>1, g>>1, b>>1)

def effect_comet_tail(leds, n, t):
    period = 1200
    pos = (t % period) / period * (n + 20)
    for i in range(n):
        dist = abs(i - pos)
        if dist < 8:
            brightness = 255 * (1 - dist/8)
            leds[i] = (255, int(brightness), int(brightness))
        else:
            leds[i] = (0,0,0)

effect_list = [
    effect_shengshi, effect_putong, effect_fade_alternate,
    effect_dual_gradient, effect_scan_bar, effect_heartbeat,
    effect_firework, effect_comet_tail
]
effect_names = [
