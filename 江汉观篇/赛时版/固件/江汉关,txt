# ========== 异步任务 ==========
async def sensor_task():
    while True:
        read_mq135()
        if current_mode == MODE_PRESET:
            update_oled()
        await asyncio.sleep_ms(30 * 60 * 1000)

async def voice_task():
    global current_mode, virtual_scene, auto_play, light_enabled, preset_index
    while True:
        cmd = parse_voice_cmd()
        if cmd:
            typ, val = cmd
            if typ == 'light_off':
                light_off()
            elif typ == 'light_on':
                light_on()
            elif typ == 'effect':
                virtual_scene = val % len(effect_list)
                if current_mode != MODE_EFFECT:
                    current_mode = MODE_EFFECT
                auto_play = False
                send_voice(f"切换到第{val+1}号效果：{effect_names[virtual_scene]}")
                update_oled()
            elif typ == 'auto_play':
                if current_mode != MODE_EFFECT:
                    current_mode = MODE_EFFECT
                auto_play = not auto_play
                send_voice("自动巡演已开启" if auto_play else "自动巡演已关闭")
                update_oled()
            elif typ == 'curtain_open':
                curtain_open()
            elif typ == 'curtain_close':
                curtain_close()
            elif typ == 'preset_temp':
                preset_index = val
                if current_mode != MODE_PRESET:
                    current_mode = MODE_PRESET
                auto_play = False
                if light_enabled:
                    update_light()
                update_oled()
            elif typ == 'report_current':
                report_current_data()
            elif typ == 'report_time':
                report_time()
        await asyncio.sleep_ms(100)

async def auto_scene_task():
    global virtual_scene, current_mode, auto_play
    while True:
        if auto_play and current_mode == MODE_EFFECT and light_enabled:
            virtual_scene = (virtual_scene + 1) % len(effect_list)
            send_voice(f"自动切换到第{virtual_scene+1}号效果：{effect_names[virtual_scene]}")
            update_oled()
        await asyncio.sleep_ms(5000)

frame_count = 0
async def led_effect_task():
    global frame_count
    while True:
        try:
            if current_mode == MODE_EFFECT and light_enabled:
                t = time.ticks_ms()
                scene = virtual_scene % len(effect_list)
                effect_list[scene](led_strip, NUM_LEDS, t)
                led_strip.write()
                frame_count += 1
                if frame_count >= 1000:
                    gc.collect()
                    frame_count = 0
                await asyncio.sleep_ms(80)
            else:
                await asyncio.sleep_ms(100)
        except Exception as e:
            print("LED effect error:", e)
            await asyncio.sleep_ms(500)

async def boot_key_task():
    global current_mode, auto_play, light_enabled
    last = 1
    press_start = 0
    click_cnt = 0
    last_release = 0
    while True:
        now = time.ticks_ms()
        val = boot_btn.value()
        if val == 0 and last == 1:
            press_start = now
        elif val == 1 and last == 0:
            duration = now - press_start
            if duration < 1000:
                if now - last_release < 500:
                    click_cnt += 1
                else:
                    click_cnt = 1
                last_release = now
                await asyncio.sleep_ms(100)
        last = val

        if click_cnt == 1:
            current_mode = MODE_EFFECT if current_mode == MODE_PRESET else MODE_PRESET
            auto_play = False
            if light_enabled and current_mode == MODE_PRESET:
                update_light()
            send_voice("切换到温度预设模式" if current_mode == MODE_PRESET else "切换到灯光效果模式")
            update_oled()
            click_cnt = 0
        elif click_cnt >= 2:
            report_current_data()
            click_cnt = 0

        await asyncio.sleep_ms(20)

