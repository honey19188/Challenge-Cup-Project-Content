    while True:
        update_oled()
        await asyncio.sleep_ms(5000)

async def main():
    gc.enable()
    send_voice("系统已启动，欢迎使用")
    await asyncio.gather(
        sensor_task(),
        voice_task(),
        auto_scene_task(),
        led_effect_task(),
        boot_key_task(),
        web_server_task(),
        ui_task()
    )

