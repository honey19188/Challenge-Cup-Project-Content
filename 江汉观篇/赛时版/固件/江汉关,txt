async def handle_client(reader, writer):
    global current_mode, virtual_scene, auto_play, light_enabled, preset_index
    try:
        request_line = await asyncio.wait_for(reader.readline(), timeout=5.0)
        if not request_line:
            await writer.aclose()
            return
        while True:
            line = await asyncio.wait_for(reader.readline(), timeout=1.0)
            if line == b'\r\n' or line == b'':
                break
        path = '/'
        try:
            parts = request_line.decode().split(' ')
            if len(parts) >= 2:
                raw_path = parts[1]
                path = raw_path.split('?')[0].rstrip('/')
            if path == '':
                path = '/'
        except:
            path = '/'
        print("HTTP req:", path)

        if path == '/':
            writer.write(b'HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n')
            writer.write(HTML_PAGE.encode())
        elif path == '/mode_preset':
            current_mode = MODE_PRESET
            auto_play = False
            if light_enabled:
                update_light()
            update_oled()
            send_voice("切换到温度预设模式")
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/mode_effect':
            current_mode = MODE_EFFECT
            auto_play = False
            update_oled()
            send_voice("切换到灯光效果模式")
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path.startswith('/temp?t='):
            try:
                t = float(raw_path.split('t=')[1].split('&')[0])
                if t == 35: idx=0
                elif t==22: idx=1
                elif t==10: idx=2
                elif t==-15: idx=3
                else: idx=preset_index
                current_mode = MODE_PRESET
                set_preset_temperature(idx)
            except:
                pass
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif '/temp_preset' in path:
            if 'first=1' in raw_path:
                set_preset_temperature(0)
            elif 'last=1' in raw_path:
                set_preset_temperature(3)
            elif 'dir=prev' in raw_path:
                set_preset_temperature(preset_index-1)
            elif 'dir=next' in raw_path:
                set_preset_temperature(preset_index+1)
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path in scene_map:
            idx = scene_map[path]
            virtual_scene = idx
            current_mode = MODE_EFFECT
            auto_play = False
            send_voice(f"切换到第{idx+1}号灯光效果：{effect_names[idx]}")
            update_oled()
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/light_off':
            light_off()
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/light_on':
            light_on()
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/auto':
            if current_mode != MODE_EFFECT:
                current_mode = MODE_EFFECT
            auto_play = not auto_play
            send_voice("自动巡演已开启" if auto_play else "自动巡演已关闭")
            update_oled()
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/report':
            report_current_data()
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
        elif path == '/shutdown':
            # 关机：关闭灯带、OLED、发送语音后进入深度睡眠
            send_voice("系统即将关机")
            # 延时等待语音播报完成
            await asyncio.sleep_ms(500)
            for i in range(NUM_LEDS):
                led_strip[i] = (0, 0, 0)
            led_strip.write()
            if oled_ok:
                oled.poweroff()
            # 发送响应后立即进入深度睡眠
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
            await writer.drain()
            await writer.aclose()
            # 延迟一点点确保数据发送完成
            await asyncio.sleep_ms(100)
            machine.deepsleep()
        elif path == '/reboot':
            send_voice("系统即将重启")
            await asyncio.sleep_ms(500)
            writer.write(b'HTTP/1.1 200 OK\r\n\r\nOK')
            await writer.drain()
            await writer.aclose()
            await asyncio.sleep_ms(100)
            machine.reset()
        else:
            writer.write(b'HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n')
            writer.write(HTML_PAGE.encode())
        await writer.drain()
    except asyncio.TimeoutError:
        pass
    except Exception as e:
        print("HTTP handler error:", e)
    finally:
        try:
            await writer.aclose()
        except:
            pass

