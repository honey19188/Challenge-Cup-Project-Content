def init_oled():
    global oled_ok, oled, i2c
    try:
        i2c = I2C(0, scl=Pin(PIN_I2C_SCL), sda=Pin(PIN_I2C_SDA), freq=5000)
        time.sleep_ms(200)
        devices = i2c.scan()
        print("I2C scan:", [hex(d) for d in devices])
        if 0x3c in devices or 0x3d in devices:
            addr = 0x3c if 0x3c in devices else 0x3d
            oled = SSD1306_I2C(128, 64, i2c, addr=addr)
            oled_ok = True
            oled.fill(0)
            oled.text("OLED Ready", 0, 0)
            oled.show()
            print("OLED initialized at", hex(addr))
        else:
            print("No OLED found")
    except Exception as e:
        print("OLED init error:", e)
        oled_ok = False

